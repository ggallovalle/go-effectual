{
    "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
    "completion": {
        "autoRequire": true,
        "callSnippet": false,
        "postfix": "@"
    },
    "diagnostics": {
        "globals": [],
        "disable": []
    },
    "doc": {
        "syntax": "md"
    },
    "strict": {
        "requirePath": true,
        "typeCall": true
    },
    "runtime": {
        "version": "Lua5.4"
    },
    "workspace": {
        "library": [
            "{luarocks}",
            "~/.luarocks/share/lua/5.4",
            "${workspaceFolder}/luahome/lua",
            "${workspaceFolder}/luahome/lua_modules/share/lua/5.4"
        ],
        "workspaceRoots": [".", "./lua"]
    }
}
