{
    "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
    "completion": {
        "autoRequire": true,
        "callSnippet": false,
        "postfix": "@"
    },
    "diagnostics": {
        "globals": [],
        "disable": []
    },
    "doc": {
        "syntax": "md"
    },
    "strict": {
        "requirePath": true,
        "typeCall": true
    },
    "runtime": {
        "version": "Lua5.2",
        "requirePattern": ["lua/?.lua", "lua/?/init.lua"]
    },
    "workspace": {
        "library": ["{luarocks}", "~/.luarocks/share/lua/5.2"],
        "workspaceRoots": [".", "./lua"]
    }
}
